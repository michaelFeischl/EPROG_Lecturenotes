ed in a new array\nend = time.time()\nprint(\"Zeit ohne out-Parameter:\", end - start)","key":"INGpYRvTyE"},{"type":"outputs","id":"26y7Nnna23v4AmiGcRvzy","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Zeit mit out-Parameter: 1.0216848850250244\nZeit ohne out-Parameter: 2.085510015487671\n"},"children":[],"key":"vMK1N7tiW0"}],"key":"WSHOOmu9I3"}],"key":"vnhrJMNeEg"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Beispiel: Die Fläche von Österreich berechnen","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"G3H3PNoXwP"}],"identifier":"beispiel-die-fl-che-von-sterreich-berechnen","label":"Beispiel: Die Fläche von Österreich berechnen","html_id":"beispiel-die-fl-che-von-sterreich-berechnen","implicit":true,"key":"JlynqxGszt"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Eine wichtige Methode in der numerischen Mathematik ist die ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"wnXwT1MIMd"},{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Monte-Carlo-Methode","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"lh2MC7nboX"}],"key":"e6YzsPy427"},{"type":"text","value":". Ein Anwendung der Methode ist die Berechnung von Flächeninhalten.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"HUL0N0aAYS"}],"key":"hUMEcNYFz7"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":4,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Man umgibt die zu berechnende Fläche mit einem Rechteck, dessen Fläche leicht zu berechnen ist.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"FWzBNyILwW"}],"key":"kf3WPzkPKO"}],"key":"VsIOy1CagX"},{"type":"listItem","spread":true,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Dann generiert man zufällige Punkte innerhalb dieses Rechtecks.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"C5fwCRjrwt"}],"key":"g92aphTCLJ"}],"key":"ZnJ68pSMZh"},{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Der Anteil der Punkte, die innerhalb der zu berechnenden Fläche liegen, entspricht dem Verhältnis der Flächeninhalte.","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"gR7SqemYGh"}],"key":"oPLmsIULsX"}],"key":"xvGly7yXAz"}],"key":"c1JypQNoTI"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Wir erinnern uns an die Funktion die überprüft ob ein Punkt innerhalb eines Polygons liegt","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"fERpST66jV"}],"key":"jWFHKywZTN"}],"key":"CgAeedh1qr"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\n# Funktion, die überprüft, ob ein Punkt innerhalb eines Polygons liegt\ndef inside_poly(poly, point):    \n    x, y = point\n    n = len(poly)\n    counter = 0\n\n    for i in range(n):\n        x1, y1 = poly[i]\n        x2, y2 = poly[(i + 1) % n]\n        if ((y1 > y) != (y2 > y)) and (x < (x2 - x1) * (y - y1) / (y2 - y1) + x1):\n            counter += 1\n\n    return counter % 2 == 1","key":"OCASYZQYHx"},{"type":"outputs","id":"lBXIi9ZN6NYnMrwXaqX36","children":[],"key":"bQCJFwzXxV"}],"key":"sT6WjMKsnc"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"Der nächste Code-Block lädt die Eckpunkte eines Polygons das die Grenzen von Österreich approximiert und berechnet das kleinste umgebende Rechteck (Bounding Box).\nDie Fläche der Bounding Box wird approximativ mit Werten aus einem Online Kartendienst berechnet (Länge x Breite).","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"uvoKYOzFPy"}],"key":"xVpra1Sq2w"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Die Eckpunkte des Polygons sind in der Datei ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"pphV2OQ56p"},{"type":"inlineCode","value":"data/austria_vertices.npy","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"WKgdhQF5gi"},{"type":"text","value":" gespeichert.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"DqZwczo2YB"}],"key":"A0jgyryTff"}],"key":"JmEuA4waD8"},{"type":"listItem","spread":true,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Die Datei wurde durch manuelles Nachzeichnen der Grenzen von Österreich in einem Online-Kartendienst erstellt","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"nP1JxBKEMs"}],"key":"T3WGfwfi0b"}],"key":"LnyEc6jEMM"}],"key":"Ymfgj3mphY"}],"key":"OlOfNGgtDu"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Lade die Grenzen von Österreich\naustria_vertices = np.load(\"data/austria_vertices.npy\")\n# Box um Österreich\nbounding_box = np.array([np.min(austria_vertices[:,0]), np.min(austria_vertices[:,1]),\n                         np.max(austria_vertices[:,0]), np.max(austria_vertices[:,1])])\nbox_area = 562 * 287  # ca. Fläche der Bounding Box in km²","key":"F432ScSOSD"},{"type":"outputs","id":"6RuZfrbDM-Vms5Doz_8Jt","children":[],"key":"zxXPD0Tt73"}],"key":"detR4FOd52"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Schließlich generieren wir zufällige Punkte innerhalb der Bounding Box und überprüfen, wie viele davon innerhalb des Polygons liegen. Daraus können wir den Flächeninhalt von Österreich abschätzen.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"fa981KgliO"}],"key":"MRez7wP9qF"}],"key":"gbID71sm7y"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Generiere zufällige Punkte innerhalb der Bounding Box\nsamples = 10000\nrandom_points = np.random.rand(samples, 2)\nrandom_points[:, 0] = random_points[:, 0] * (bounding_box[2] - bounding_box[0]) + bounding_box[0]\nrandom_points[:, 1] = random_points[:, 1] * (bounding_box[3] - bounding_box[1]) + bounding_box[1]\n\n# Überprüfe, ob die Punkte innerhalb oder außerhalb des Polygons liegen\npoints_inside = np.array([inside_poly(austria_vertices, point) for point in random_points])\nprint(f\"Anteil der Punkte innerhalb von Österreich: {np.sum(points_inside==True)/samples:.2%}\")\nprint(f\"Geschätzte Fläche von Österreich: {np.sum(points_inside==True)/samples * box_area:.2f} (tatsächlich ca. 83883 km²)\")","key":"TL9URAeOKm"},{"type":"outputs","id":"Td3RzNgrD0veUwPmGbUyV","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Anteil der Punkte innerhalb von Österreich: 52.48%\nGeschätzte Fläche von Österreich: 84647.09 (tatsächlich ca. 83883 km²)\n"},"children":[],"key":"FNejBWODdP"}],"key":"BzfaEtXkzl"}],"key":"VyEJTSONPx"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Letztlich visualisieren wir das Polygon, die Bounding Box und die zufällig generierten Punkte.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"HBslcm0xox"}],"key":"rpRZLAbvpN"}],"key":"ccLUZSiENv"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Visualisierung der Berechnung\nplt.figure(figsize=(8, 8))\nplt.plot(austria_vertices[:, 0], austria_vertices[:, 1], 'b-', marker='o')\nplt.fill(austria_vertices[:, 0], austria_vertices[:, 1], alpha=0.2, color='blue')\nplt.plot([bounding_box[0], bounding_box[2], bounding_box[2], bounding_box[0], bounding_box[0]],\n         [bounding_box[1], bounding_box[1], bounding_box[3], bounding_box[3], bounding_box[1]], 'r--')\nplt.scatter(random_points[points_inside,0], random_points[points_inside,1], color='red', s=1, alpha=0.5)\nplt.scatter(random_points[~points_inside,0], random_points[~points_inside,1], color='green', s=1, alpha=0.5)\nplt.xticks([])\nplt.yticks([])\nplt.axis('equal')\nplt.show()","key":"Kr2JHzkmL3"},{"type":"outputs","id":"DBoj6pC4CE8lmRZlYJqKU","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"c5e21ec5d63f60245cc6268d044fad9e","path":"/c5e21ec5d63f60245cc6268d044fad9e.png"},"text/plain":{"content":"<Figure size 800x800 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"f1tVTXPDAI"}],"key":"rNXZiMTIEP"}],"key":"T7kazYevLj"}],"key":"c4WCg4KMHc"},"references":{"cite":{"order":[],"data":{}}}}
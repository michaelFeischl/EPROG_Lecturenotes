 + 210x^6y^4 + 252x^5y^5 + 210x^4y^6 + 120x^3y^7 + 45x^2y^8 + 10xy^9 + y^10\n"},"children":[],"key":"FaW7O0PdjO"}],"key":"blsY2krVYo"}],"key":"axJk2V21Jr"}],"key":"ttd8j4Mgh9"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Weitere Datentypen","url":"/datatypes","group":"EPROG 2025"},"next":{"title":"Funktionen","url":"/functions","group":"EPROG 2025"}}},"domain":"http://localhost:3001"}